# AI Model Settings (OpenAI-compatible API)
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=your_api_key_here
AI_MODEL=gpt-4o-mini

# Embedding Model (for semantic search)
AI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# App Settings
APP_HOST=0.0.0.0
APP_PORT=8080
APP_TITLE=پایگاه نظریات حقوقی

# CSV Path (relative or absolute)
CSV_PATH=opinions.csv

# SQLite DB Path (auto-created from CSV)
DB_PATH=law.db

# Semantic search: number of results to return
SEMANTIC_TOP_K=20

# Chatbot system prompt (optional override)
# CHAT_SYSTEM_PROMPT=...
